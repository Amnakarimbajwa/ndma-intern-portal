<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Admin — All Intern Progress</title>
  <style>
    body { font-family: system-ui, sans-serif; background:#f4f6f9; margin:0; color:#222; }
    header { background:#0f2540; color:#fff; padding:16px 24px; display:flex; justify-content:space-between; align-items:center; }
    header a { color:#fff; text-decoration:none; font-size:13px; opacity:.85; margin-left:16px; }
    .wrap { max-width:1100px; margin:24px auto; padding:0 16px; }
    .filters { background:#fff; padding:14px; border-radius:8px; margin-bottom:16px; display:flex; gap:10px; align-items:center; }
    select, input { padding:8px; border:1px solid #ccc; border-radius:6px; }
    .stat { font-size:13px; color:#555; margin-bottom:12px; }
    table { width:100%; border-collapse:collapse; background:#fff; border-radius:8px; overflow:hidden; }
    th, td { text-align:left; padding:10px 12px; border-bottom:1px solid #eee; font-size:13px; vertical-align:top; }
    th { background:#eef1f6; color:#333; }
    .btn { padding:8px 14px; background:#0f2540; color:#fff; border-radius:6px; text-decoration:none; font-size:13px; font-weight:600; }
  </style>
</head>
<body>
  <header>
    <div>NDMA Admin — Weekly Progress (<%= totalInterns %> interns)</div>
    <div><a href="/admin/logout">Log out</a></div>
  </header>
  <div class="wrap">
    <form class="filters" method="GET" action="/admin">
      <label>Week:</label>
      <select name="week">
        <option value="">All</option>
        <% weeks.forEach(w => { %>
          <option value="<%= w %>" <%= filters.week == w ? 'selected' : '' %>>Week <%= w %></option>
        <% }) %>
      </select>
      <label>Intern:</label>
      <input type="text" name="intern" placeholder="Search by name" value="<%= filters.intern || '' %>">
      <button class="btn" type="submit">Filter</button>
      <a class="btn" href="/admin/export<%= filters.week ? '?week=' + filters.week : '' %><%= filters.intern ? (filters.week ? '&' : '?') + 'intern=' + filters.intern : '' %>">⬇ Export Excel</a>
    </form>

    <div class="stat"><%= submissions.length %> submission(s) matching current filter</div>

    <table>
      <tr><th>Week</th><th>Intern</th><th>University</th><th>Task</th><th>Attachments</th><th>Updated</th></tr>
      <% submissions.forEach(s => { %>
        <tr>
          <td>Week <%= s.week_number %></td>
          <td><%= s.full_name %></td>
          <td><%= s.university %></td>
          <td><%= s.task_text %></td>
          <td>
            <% (s.attachments ? s.attachments.split(',') : []).forEach(f => { %>
              <a href="<%= f %>" target="_blank">📎</a>
            <% }) %>
          </td>
          <td><%= new Date(s.updated_at).toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </table>
  </div>
</body>
</html>
