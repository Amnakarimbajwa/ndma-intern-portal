<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Week <%= week %> — Submit Progress</title>
  <style>
    body { font-family: system-ui, sans-serif; background:#f4f6f9; margin:0; color:#222; }
    header { background:#0f2540; color:#fff; padding:16px 24px; display:flex; justify-content:space-between; align-items:center; }
    header a { color:#fff; text-decoration:none; font-size:13px; opacity:.85; }
    .wrap { max-width:640px; margin:24px auto; padding:0 16px; }
    .card { background:#fff; border-radius:10px; padding:24px; box-shadow:0 2px 8px rgba(0,0,0,.05); }
    label { display:block; font-size:13px; font-weight:600; margin:14px 0 6px; color:#333; }
    textarea, input[type=date] { width:100%; padding:10px; border:1px solid #ccc; border-radius:6px; box-sizing:border-box; font-family:inherit; }
    textarea { min-height:160px; resize:vertical; }
    button { margin-top:18px; padding:10px 20px; background:#0f2540; color:#fff; border:none; border-radius:6px; font-weight:600; cursor:pointer; }
    .error { color:#c0392b; font-size:13px; margin-bottom:12px; }
    .existing { background:#eef1f6; padding:10px; border-radius:6px; font-size:13px; margin-bottom:14px; }
  </style>
</head>
<body>
  <header>
    <div>Week <%= week %> Progress — <%= intern.name %></div>
    <a href="/dashboard">← Back to dashboard</a>
  </header>
  <div class="wrap">
    <div class="card">
      <% if (error) { %><div class="error"><%= error %></div><% } %>
      <% if (existing) { %>
        <div class="existing">You already submitted Week <%= week %>. Submitting again will update this entry.</div>
      <% } %>
      <form method="POST" action="/submit/<%= week %>" enctype="multipart/form-data">
        <label>Week start date (optional)</label>
        <input type="date" name="weekStartDate" value="<%= existing && existing.week_start_date ? existing.week_start_date.toISOString().substring(0,10) : '' %>">

        <label>What did you work on this week?</label>
        <textarea name="taskText" placeholder="Describe the tasks you completed this week..." required><%= existing ? existing.task_text : '' %></textarea>

        <label>Attach files (optional — reports, sheets, images)</label>
        <input type="file" name="attachments" multiple>

        <button type="submit"><%= existing ? 'Update Submission' : 'Submit' %></button>
      </form>
    </div>
  </div>
</body>
</html>
