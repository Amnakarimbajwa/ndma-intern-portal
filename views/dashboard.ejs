<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>My Weekly Progress</title>
  <style>
    body { font-family: system-ui, sans-serif; background:#f4f6f9; margin:0; color:#222; }
    header { background:#0f2540; color:#fff; padding:16px 24px; display:flex; justify-content:space-between; align-items:center; }
    header a { color:#fff; text-decoration:none; font-size:13px; opacity:.85; }
    .wrap { max-width:900px; margin:24px auto; padding:0 16px; }
    h2 { font-size:16px; color:#0f2540; margin:24px 0 12px; }
    .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(140px,1fr)); gap:10px; }
    .week-btn { display:block; text-align:center; padding:14px 8px; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px; }
    .done { background:#e6f4ea; color:#1e7e34; border:1px solid #b7e0c2; }
    .pending { background:#fff; color:#0f2540; border:1px solid #d7dce3; }
    table { width:100%; border-collapse:collapse; background:#fff; border-radius:8px; overflow:hidden; }
    th, td { text-align:left; padding:10px 12px; border-bottom:1px solid #eee; font-size:14px; }
    th { background:#eef1f6; color:#333; }
    .empty { color:#888; font-size:14px; padding:16px; text-align:center; }
  </style>
</head>
<body>
  <header>
    <div>NDMA Internship Portal — <%= intern.name %></div>
    <a href="/logout">Log out</a>
  </header>
  <div class="wrap">
    <h2>Select a week to submit or edit</h2>
    <div class="grid">
      <% weeks.forEach(w => { %>
        <a class="week-btn <%= submittedWeeks.has(w) ? 'done' : 'pending' %>" href="/submit/<%= w %>">
          Week <%= w %><br><small><%= submittedWeeks.has(w) ? '✓ Submitted' : 'Not submitted' %></small>
        </a>
      <% }) %>
    </div>

    <h2>Submission history</h2>
    <% if (submissions.length === 0) { %>
      <div class="empty">No submissions yet. Pick a week above to get started.</div>
    <% } else { %>
      <table>
        <tr><th>Week</th><th>Monday</th><th>Tuesday</th><th>Wednesday</th><th>Thursday</th><th>Summary</th><th>Project Title</th><th>Project Explanation</th><th>Last Updated</th></tr>
        <% submissions.forEach(s => { %>
          <tr>
            <td>Week <%= s.week_number %></td>
            <td><%= s.monday_text || '—' %></td>
            <td><%= s.tuesday_text || '—' %></td>
            <td><%= s.wednesday_text || '—' %></td>
            <td><%= s.thursday_text || '—' %></td>
            <td><%= s.summary_text || '—' %></td>
            <td><%= s.project_title || '—' %></td>
            <td><%= s.project_description || '—' %></td>
            <td><%= new Date(s.updated_at).toLocaleString() %></td>
          </tr>
        <% }) %>
      </table>
    <% } %>
  </div>
</body>
</html>
